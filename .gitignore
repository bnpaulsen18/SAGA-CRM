# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem
.sentryclirc

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

/lib/generated/prisma

# impeccable design skill — full source repo vendored here for `git pull` updates.
# The actually-used skill is installed at .claude/skills/impeccable (kept in git).
/.impeccable

# awesome-ux-skills installer clone — skills are copied to ~/.claude/skills (global),
# so this clone is only kept for re-running ./install.sh; safe to delete.
/awesome-ux-skills

# voice cofounder tool — its own isolated dependency
/voice/node_modules
# talk-back mute toggle (local; delete the file to mute spoken replies)
/voice/voice-out.on

# shell-redirect junk + dev/audit artifacts (these kept recurring at the repo root)
_ul
_ul-*
*.log
lighthouse-report.*

# stray local HTML mockups / asset bundles at the repo root (real assets live in public/)
/*.html
/*.zip
