# Database
DATABASE_URL="postgresql://..."
DIRECT_URL="postgresql://..."

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"

# OAuth Providers (Optional - Social Authentication)
# Google OAuth - Get from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Microsoft Azure AD OAuth - Get from: https://portal.azure.com/#blade/Microsoft_AAD_RegisteredApps/ApplicationsListBlade
AZURE_AD_CLIENT_ID=""
AZURE_AD_CLIENT_SECRET=""
AZURE_AD_TENANT_ID="common"  # "common" allows any Microsoft account

# Email Service (Optional - Resend)
RESEND_API_KEY="re_..."

# Cloudflare Turnstile CAPTCHA (Optional)
# Get keys from: https://dash.cloudflare.com/turnstile
NEXT_PUBLIC_TURNSTILE_SITE_KEY="0x4AAAAAAA..."
TURNSTILE_SECRET_KEY="0x4AAAAAAA..."

# Google Analytics 4 (Optional)
# Get measurement ID from: https://analytics.google.com
# Format: G-XXXXXXXXXX
# Only loads if user consents to analytics cookies
NEXT_PUBLIC_GA_MEASUREMENT_ID=""

# Stripe (Required for Pro/Enterprise - Online Donations)
# Get from: https://dashboard.stripe.com/apikeys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."  # Publishable key (public)
STRIPE_SECRET_KEY="sk_test_..."                    # Secret key (private)
STRIPE_WEBHOOK_SECRET="whsec_..."                  # Webhook signing secret

# Stripe Connect (Required for Platform Fee Collection)
# Get from: https://dashboard.stripe.com/settings/applications
# Create a Connect application first, then copy the Client ID
STRIPE_CONNECT_CLIENT_ID="ca_..."

# Vercel KV (Required for Rate Limiting)
# Auto-populated when you create Vercel KV database
# Create at: https://vercel.com/dashboard/stores
KV_REST_API_URL=""
KV_REST_API_TOKEN=""

# Anthropic Claude API (Optional - AI Features)
# Get from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY="sk-ant-..."
